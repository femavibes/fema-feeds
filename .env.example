# Database (used by API and migrations)
DATABASE_URL=postgresql://cfb:cfb_dev@postgres:5432/custom_feed_builder

# API server
API_PORT=3000

# Bluesky Jetstream for firehose ingestion
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe

# Bluesky public API
BSKY_PUBLIC_API=https://public.api.bsky.app

# Engagement refresh (seconds between each batch refresh of pool post engagement)
# ENGAGEMENT_REFRESH_INTERVAL_SEC=60
# ENGAGEMENT_REFRESH_MAX_AGE_HOURS=48

# DuckDNS (for ez/VPS deployment with auto HTTPS)
# DUCKDNS_SUBDOMAIN=your-subdomain
# DUCKDNS_TOKEN=your-token

# Cloudflare Tunnel (for home deployment behind NAT)
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
# FEEDGEN_PUBLIC_URL=https://feeds.yourdomain.com
