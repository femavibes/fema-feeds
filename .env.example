# Default Jetstream endpoint (same as ATlas Near You — subscription.ts)
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe

# Postgres (docker compose)
DATABASE_URL=postgresql://cfb:cfb_dev@localhost:5432/custom_feed_builder

# Bluesky public API for list resolution
BSKY_PUBLIC_API=https://public.api.bsky.app

# ── Feed publishing (pick one profile) ──────────────────────────────────────
#
# Home PC — Tailscale Funnel (no domain, no port forwarding):
#   1. Install Tailscale, enable Funnel in admin console
#   2. API running on :3000, then: .\scripts\start-feedgen-tailscale.ps1
#   3. Paste the https://….ts.net URL in Settings → Tailscale Funnel
#
# Home PC — your own domain on Cloudflare:
#   1. Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
#   2. Public Hostname → Service: http://api:3000 (Docker) or http://127.0.0.1:3000 (native)
#   3. Set both values below, then: .\scripts\docker-up.ps1 -Profile home
# CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
# FEEDGEN_PUBLIC_URL=https://feeds.yourdomain.com
#
# VPS / cloud server — public IP + free DuckDNS hostname:
#   Set subdomain + token, then: .\scripts\docker-up.ps1 -Profile vps
# DUCKDNS_SUBDOMAIN=femafeeds
# DUCKDNS_TOKEN=your-token-from-duckdns.org
#
# Advanced — your own domain with manual DNS (A record + HTTPS reverse proxy)

# Bluesky OAuth — fema.monster deployment URL (not feedgen URL). Provision before anyone logs in:
#   CFB_DEPLOYMENT_SLUG=myfeeds ./scripts/provision-feed-url.sh
# → OAUTH_PUBLIC_URL=https://myfeeds.feeds.fema.monster (written automatically)
# Open the app at that URL — OAuth callback and session cookies share the same origin.

# ── Global marketplace (feed-builder VPS: no config required) ─────────────
# Global catalog defaults to https://marketplace.fema.monster
# Global submissions from My collection are forwarded to the registry for review.
#
# Dev overrides:
# CFB_GLOBAL_MARKETPLACE_URL=http://127.0.0.1:3000
# CFB_GLOBAL_MARKETPLACE_EMBEDDED=true
#
# Local all-in-one registry testing (never on a public feed-builder VPS):
# CFB_REGISTRY_DEV=true
# OAUTH_PUBLIC_URL=http://localhost:3000
